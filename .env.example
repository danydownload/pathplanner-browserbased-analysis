DJANGO_DEBUG=0
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=pathplanner.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://pathplanner.example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_STATIC_ROOT=/app/staticfiles
DJANGO_MEDIA_ROOT=/app/uploads
DJANGO_SQLITE_PATH=/app/data/db.sqlite3
MAPBOX_ACCESS_TOKEN=
OPENAQ_API_KEY=

# Optional demo routing engine. When set, backend clinical routing first asks a
# local/self-hosted GraphHopper instance for real OSM route candidates, scores
# them with the app's clinical/environmental weights, and falls back to Overpass
# street-graph A* if GraphHopper is unavailable.
GRAPHHOPPER_URL=
GRAPHHOPPER_API_KEY=
GRAPHHOPPER_TIMEOUT_SECONDS=8
GRAPHHOPPER_FORCE=false
GRAPHHOPPER_PROFILE_WALKING=foot
GRAPHHOPPER_PROFILE_CYCLING=bike
GRAPHHOPPER_PROFILE_CAR=car

# Local OSM-derived POI/walkability database. On a server, mount the PBF and
# runtime directory, then run scripts/ensure_local_osm_poi_db.py or enable the
# optional Docker entrypoint bootstrap.
LOCAL_OSM_POI_DB=/app/runtime/local_osm_pois/italy.sqlite3
LOCAL_OSM_PBF_PATH=/app/pbf/italy-260626.osm.pbf
LOCAL_OSM_POI_BUILD_MODE=full
LOCAL_OSM_POI_MIN_ROWS=1
LOCAL_OSM_WALKABILITY_MIN_ROWS=1
LOCAL_OSM_POI_FORCE_REBUILD=false
PATHPLANNER_ENSURE_LOCAL_OSM_DB=false
