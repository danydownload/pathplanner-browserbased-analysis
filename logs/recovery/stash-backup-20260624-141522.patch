+// ---------------------------------------------------------------------------
+// Positive-only preference cost model (PP-ASTAR-FIX).
+// Every preference term is a PENALTY (>= 0), never a reward. This keeps each
+// edge cost >= its geometric distance, so the straight-line heuristic stays
+// admissible AND consistent — the no-reopen A* loop below is then provably
+// correct (no closed-node re-opening, no oscillation/backtracking).
+// ---------------------------------------------------------------------------
+const POI_PREF_DIST_SCALE_M = 200;   // proximity scale for exp(-d/scale)
+const POI_PREF_MAX_PENALTY = 5;      // max penalty (m-equiv) per unit weight
+const DETOUR_CAP = 1.3;              // route length <= cap * straight-line ...
+const DETOUR_SLACK_FACTOR = 2;       // ... + this many grid cells of slack
+
+// POI proximity preference expressed as a non-negative penalty.
+//   weight > 0 (prefer near): 0 at the feature, -> weight*MAX far away.
+//   weight < 0 (prefer far):  weight*MAX at the feature, -> 0 far away.
+// Same gradient as the old negative reward, sign-flipped so cost never drops.
+function preferencePenalty(weight, nearestDistanceMeters) {
+    if (!weight || typeof weight !== 'number' || !Number.isFinite(nearestDistanceMeters)) {
+        return 0;
     }
-    return cost;
+    const near = Math.exp(-nearestDistanceMeters / POI_PREF_DIST_SCALE_M); // (0,1]
+    return weight > 0
+        ? weight * POI_PREF_MAX_PENALTY * (1 - near)
+        : -weight * POI_PREF_MAX_PENALTY * near;
+}
+
+// Env-proxy preference deficit penalty (keeps the original 0.8 gradient, but as
+// a non-negative deficit instead of a negative reward). value in [0, valueMax],
+// higher value = more of the feature.
+//   weight > 0 wants the feature (penalty grows as value drops below max).
+//   weight < 0 avoids it (penalty grows with the value present).
+function proxyPref(weight, value, valueMax) {
+    if (!weight || value == null) return 0;
+    const v = Math.max(0, Math.min(valueMax, value));
+    return weight > 0
+        ? weight * 0.8 * (valueMax - v)
+        : -weight * 0.8 * v;
+}
+
+function applyPreferencePoiAdjustment(cost, weight, nearestDistanceMeters) {
+    return cost + preferencePenalty(weight, nearestDistanceMeters);
 }
 
