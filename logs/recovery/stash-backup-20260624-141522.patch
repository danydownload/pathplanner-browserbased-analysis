+/**
+ * Pure-distance shortest path between two points (no preference/POI shaping).
+ * Used for via-point legs so each leg is monotonic and forward-moving.
+ */
+async function shortestPathLeg(start, goal, map, gridResolution) {
+    return findOptimalRoute(start, goal, map, { name: 'default' }, null, gridResolution, null, null);
+}
+
+/**
+ * (B) Explicit "pass through a park": pick the best park within the detour
+ * budget, then route two PLAIN shortest-path legs A->park and park->B. Returns
+ * a {route, environmentalScore, viaPoint} object, or null when no park fits the
+ * budget (caller then falls back to the positive-cost A*).
+ * @param {Array} parkList - candidate park coordinates [{lat, lon}]
+ */
+async function findViaParkRoute(start, goal, map, gridResolution, parkList) {
+    if (!parkList || parkList.length === 0) return null;
+
+    const directDistance = calculateDistance(start, goal);
+    const budget = DETOUR_CAP * directDistance;
+
+    // Pick the park that adds the LEAST detour (closest to the straight line),
+    // so the resulting route is sensible and forward-moving.
+    let bestPark = null;
+    let bestDetour = Infinity;
+    for (const park of parkList) {
+        if (typeof park?.lat !== 'number' || typeof park?.lon !== 'number') continue;
+        const detour = calculateDistance(start, park) + calculateDistance(park, goal);
+        if (detour <= budget && detour < bestDetour) {
+            bestDetour = detour;
+            bestPark = park;
+        }
+    }
+    if (!bestPark) return null;
+
+    const via = { lat: bestPark.lat, lon: bestPark.lon };
+    const [legA, legB] = await Promise.all([
+        shortestPathLeg(start, via, map, gridResolution),
+        shortestPathLeg(via, goal, map, gridResolution),
+    ]);
+    const routeA = legA?.route || [];
+    const routeB = legB?.route || [];
+    if (routeA.length === 0 || routeB.length === 0) return null;
+
+    // Concatenate, dropping the duplicated junction node.
+    const combined = routeA.concat(routeB.slice(1));
+    return {
+        route: combined,
+        environmentalScore: (legA.environmentalScore || 0) + (legB.environmentalScore || 0),
+        viaPoint: via,
+    };
+}
